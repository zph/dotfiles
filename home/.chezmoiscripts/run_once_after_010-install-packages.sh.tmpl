#!/usr/bin/env bash

set -eou pipefail

# Ensure brew is on PATH (needed on first run after fresh install)
if ! command -v brew &>/dev/null; then
  if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
  elif [[ -x /usr/local/bin/brew ]]; then
    eval "$(/usr/local/bin/brew shellenv)"
  fi
fi

# Brewfile hash: {{ include "../home/dot_config/brewfile/Brewfile.extras" | sha256sum }}
# Brewfile hash: {{ include "../home/dot_config/brewfile/Brewfile.base" | sha256sum }}
~/bin/brew-apply
