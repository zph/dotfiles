# Strip the Dock down to only running apps.
# On modern macOS (Sequoia+), clearing persistent-apps alone is not enough —
# the OS will still show "suggested" and "recent" apps in the Dock.
# We need all three settings:
#   1. persistent-apps/others -array  → remove explicitly pinned icons
#   2. show-recents false             → hide the "recent apps" section
#   3. static-only true               → show ONLY running apps, nothing else
echo "# Clear all pinned Dock icons and set Dock to static-only mode"
defaults write com.apple.dock persistent-apps -array
defaults write com.apple.dock persistent-others -array
defaults write com.apple.dock show-recents -bool false
defaults write com.apple.dock static-only -bool true

# Restart the Dock to apply changes
echo "# Restart the Dock to apply changes"
killall Dock

